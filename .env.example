# Clé API LLM (OpenRouter recommandé — accès à tous les modèles)
LLM_API_KEY=sk-or-v1-xxxx
LLM_MODEL=google/gemma-3-4b-it:free   # modèle gratuit léger, parfait pour Pi

# Optionnel — alertes Telegram
TELEGRAM_TOKEN=
TELEGRAM_USER_ID=

# Optionnel — recherche web
BRAVE_API_KEY=

# Config ferme
POLL_INTERVAL=30       # lecture capteurs (secondes)
SECRET_KEY=change_me   # clé interne API